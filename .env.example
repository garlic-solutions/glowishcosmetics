# Hygraph (GraphQL Content API – read-only public endpoint)
NEXT_PUBLIC_HYGRAPH_ENDPOINT=https://your-region.cdn.hygraph.com/content/your-project-id/master

# Hygraph (Mutations – needs a permanent auth token with Editor/Admin role)
HYGRAPH_MUTATION_TOKEN=your_permanent_auth_token_here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_32_character_nextauth_secret_here
